# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Google OAuth (Calendar sync)
# Get from console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Stripe Connect
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Knock (notifications — email + SMS)
# Get from app.knock.app → Developers → API Keys
KNOCK_SECRET_API_KEY=sk_...
NEXT_PUBLIC_KNOCK_PUBLIC_API_KEY=pk_...
KNOCK_SIGNING_KEY=

# Twilio / SMS provider (configured via Knock dashboard — add credentials there, not here)
# Direct Twilio keys only needed if bypassing Knock for SMS

# Resend (transactional email — configured as Knock email channel)
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=

# Sentry (error tracking)
# Create project at sentry.io, get DSN from Settings → Projects → Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=your-sentry-org-slug
SENTRY_AUTH_TOKEN=sntrys_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron jobs (Vercel calls these endpoints — validate with CRON_SECRET header)
# Generate: openssl rand -hex 32
CRON_SECRET=
